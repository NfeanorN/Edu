{
  "show": "Аватар: Легенда об Аанге",
  "season": 1,
  "episode": 5,
  "title": "Король Омашу",
  "source": "https://avatar-legenda-ob-aange-hdrezka.org/238-subtitles/1-season/5-episode",
  "entries": [
    { "id": 1, "start": "00:00:01,000", "end": "00:00:04,500", "text": "[Тематическая заставка]" },
    { "id": 2, "start": "00:00:05,000", "end": "00:00:08,200", "text": "Ранее в Аватаре..." },
    { "id": 3, "start": "00:00:10,000", "end": "00:00:14,000", "text": "— Мы направляемся в Омашу." },
    { "id": 4, "start": "00:00:14,500", "end": "00:00:18,000", "text": "— Там мы сможем пересечь царство Земли." },
    { "id": 5, "start": "00:00:20,000", "end": "00:00:24,500", "text": "— Сока, что это за город?" },
    { "id": 6, "start": "00:00:25,000", "end": "00:00:29,000", "text": "— Омашу — один из старейших городов царства Земли." },
    { "id": 7, "start": "00:00:30,000", "end": "00:00:34,500", "text": "— И один из самых хорошо защищённых." },
    { "id": 8, "start": "00:00:35,000", "end": "00:00:39,000", "text": "— Никто не смог его захватить за сто лет войны." },
    { "id": 9, "start": "00:00:42,000", "end": "00:00:46,000", "text": "— Эй! Вы трое! Остановитесь!" },
    { "id": 10, "start": "00:00:47,000", "end": "00:00:51,500", "text": "— Нас заметили. Что будем делать?" },
    { "id": 11, "start": "00:00:52,000", "end": "00:00:56,000", "text": "— Продолжаем идти. Мы просто путешественники." },
    { "id": 12, "start": "00:01:00,000", "end": "00:01:05,000", "text": "— Стражники ведут нас к королю. Это может быть хорошо." },
    { "id": 13, "start": "00:01:08,000", "end": "00:01:12,500", "text": "— Или очень плохо." },
    { "id": 14, "start": "00:01:15,000", "end": "00:01:20,000", "text": "[Добавьте сюда субтитры со страницы — скопируйте с сайта и вставьте в entries]" }
  ]
}
